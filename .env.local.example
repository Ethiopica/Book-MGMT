NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin: only this email can approve users (must match exactly)
NEXT_PUBLIC_ADMIN_EMAIL=your_admin_email@example.com
ADMIN_EMAIL=your_admin_email@example.com

# Required for admin approve API (Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: send borrower confirmation email when a book is lent (Nodemailer + Gmail SMTP)
# Use an app password (recommended) for your Gmail account.
EMAIL_USER=yourgmailaddress@gmail.com
EMAIL_PASS=your_gmail_app_password
# Optional: custom from header (otherwise defaults to EMAIL_USER)
NOTIFY_FROM_EMAIL=Church Library <yourgmailaddress@gmail.com>
