NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin: only this email can approve users (must match exactly)
NEXT_PUBLIC_ADMIN_EMAIL=your_admin_email@example.com
ADMIN_EMAIL=your_admin_email@example.com

# Required for admin approve API (Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: send borrower confirmation email when a book is lent (Resend.com)
# Get API key at https://resend.com → API Keys. Without this, lending still works; no email is sent.
RESEND_API_KEY=re_xxxxxxxxxxxx
# Required to send to borrowers (not just yourself): verify a domain at https://resend.com/domains,
# then set the "from" address to an email on that domain. Without this, Resend only allows sending to your own email.
# RESEND_FROM_EMAIL=Church Library <library@yourchurch.org>
